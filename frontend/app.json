{
  "expo": {
    "name": "Lato Estoque",
    "slug": "lato-estoque",
    "scheme": "latoestoque",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F141A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.latoestoque.app",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#0F141A"
      }
    },
    "plugins": [
      "expo-barcode-scanner",
      "expo-asset"
    ]
  }
}
